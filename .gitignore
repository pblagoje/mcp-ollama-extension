# ============================================================================
# VS Code Extension .gitignore
# ============================================================================

# Compiled output
out/
dist/
*.vsix

# Node.js dependencies
node_modules/

# TypeScript cache
*.tsbuildinfo

# Test artifacts
.vscode-test/
.vscode-test-web/

# Build artifacts
*.js.map
*.d.ts.map

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Environment variables
.env
.env.local
.env.*.local

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE / Editor specific
.vscode/settings.json
.vscode/launch.json
.vscode/tasks.json
.idea/
*.swp
*.swo
*~

# Coverage reports
coverage/
.nyc_output/
*.lcov

# Temporary files
tmp/
temp/
*.tmp

# Package manager locks (keep package-lock.json for reproducibility)
# Uncomment if you prefer to ignore:
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# Webpack cache
.cache/

# ESLint cache
.eslintcache

# Cursor AI editor
.cursorignore
.cursorindexingignore

# macOS
.AppleDouble
.LSOverride

# Windows
ehthumbs.db
ehthumbs_vista.db

# Linux
.directory
.Trash-*